# ============================================
# 本地开发环境变量配置模板
# 复制为 .env 后修改为自己的值（.env 不提交到 Git）
# cp .env.example .env
# ============================================

# --- 数据库 ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=smart_recruitment
DB_USERNAME=root
DB_PASSWORD=你的MySQL密码

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Elasticsearch ---
ES_HOST=localhost
ES_PORT=9200

# --- Nacos ---
NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_DISCOVERY_IP=127.0.0.1

# --- AI 服务 ---
AI_SERVICE_URL=http://localhost:8081
OPENAI_API_KEY=sk-placeholder
OPENAI_BASE_URL=https://api.openai.com

# --- Docker 镜像版本（各人可用不同版本） ---
REDIS_IMAGE=redis/redis-stack:latest
ES_IMAGE=elasticsearch:8.18.6
NACOS_IMAGE=nacos/nacos-server:v2.4.3

# Smart Recruitment local development environment example.
# Copy this file to .env and adjust values for your own machine.
# PowerShell: Copy-Item .env.example .env
# macOS/Linux: cp .env.example .env
#
# .env is ignored by Git. Do not commit real passwords or API keys.
# Spring Boot does not automatically load .env unless your IDE/run script imports it.

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=smart_recruitment
DB_USERNAME=root
DB_PASSWORD=root

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_IMAGE=redis/redis-stack:latest

# Elasticsearch
ES_HOST=127.0.0.1
ES_PORT=9200
ES_IMAGE=elasticsearch:7.17.21

# Nacos
NACOS_SERVER_ADDR=127.0.0.1:8848
# Usually leave blank so the client detects a reachable address automatically.
# Set this explicitly only for multi-NIC hosts or special container networking.
NACOS_DISCOVERY_IP=
NACOS_CONFIG_GROUP=SMART_RECRUITMENT
NACOS_DISCOVERY_GROUP=SMART_RECRUITMENT
NACOS_NAMESPACE=
# Leave blank while Docker Nacos authentication is disabled.
NACOS_USERNAME=
NACOS_PASSWORD=
NACOS_INIT_MAX_WAIT_SECONDS=120
NACOS_IMAGE=nacos/nacos-server:v2.2.3

# AI service and OpenAI-compatible model provider
# Leave unset in dev so Feign uses Nacos service discovery.
# AI_SERVICE_URL=http://localhost:8081
OPENAI_API_KEY=sk-placeholder
OPENAI_BASE_URL=https://api.openai.com

# JWT
JWT_SECRET=recruitment-system-secret-key-must-be-at-least-256-bits
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# File upload
FILE_UPLOAD_DIR=uploads
